{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "VITE_OIDC_AUTHORITY",
        "VITE_OIDC_CLIENT_ID",
        "VITE_API_BASE",
        "VITE_EVENTS_URL",
        "VITE_ARTIFACTS_BASE",
        "VITE_USE_MOCK",
        "VITE_STREAM_URL"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": { "dependsOn": ["^lint"] },
    "typecheck": { "dependsOn": ["^typecheck"] },
    "test": { "dependsOn": ["^test"] },
    "dev": { "cache": false, "persistent": true }
  }
}
